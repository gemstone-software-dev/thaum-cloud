{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Image",
      "url": {{ (base_url ~ "/static/Thaum_wizard_cgi.jpg") | tojson }},
      "height": "256px"
    },
    {
      "type": "TextBlock",
      "text": {{ ("How can " ~ team_description ~ " help you today?") | tojson }},
      "wrap": true
    },
    {
      "type": "Input.Text",
      "id": "summary",
      "label": "Summary",
      "placeholder": "Briefly describe what you need",
      "isMultiline": true,
      "isRequired": true
    },
    {
      "type": "Input.Toggle",
      "id": "is_emergency",
      "title": "High priority (emergency) alert",
      "value": {{ ("true" if default_high_priority else "false") | tojson }},
      "valueOn": "true",
      "valueOff": "false",
      "isVisible": {{ show_priority_toggle | tojson }}
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit",
      "data": {
        "action": "submit_incident"
      }
    }
  ]
}
