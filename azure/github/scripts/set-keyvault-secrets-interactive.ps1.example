# SPDX-License-Identifier: MPL-2.0
# Prompt for each Key Vault secret value (hidden input) and upload without putting values on the command line.
# Copy to set-keyvault-secrets-interactive.ps1 and run, e.g.:
#   .\set-keyvault-secrets-interactive.ps1 -VaultName myvault -SecretName webex-token-database, other-secret
#   .\set-keyvault-secrets-interactive.ps1 -VaultName myvault -SecretName @('a','b') -Subscription "00000000-0000-0000-0000-000000000000"
#
# Requires: Az.KeyVault (e.g. Install-Module Az.KeyVault -Scope CurrentUser)
# Uses: Set-AzKeyVaultSecret -SecretValue (from Read-Host -AsSecureString)
# Reference: https://learn.microsoft.com/en-us/powershell/module/az.keyvault/set-azkeyvaultsecret

param(
    [Parameter(Mandatory = $true, HelpMessage = "Key Vault name")]
    [string] $VaultName,

    [Parameter(Mandatory = $true, HelpMessage = "One or more secret names to set")]
    [string[]] $SecretName,

    [Parameter(Mandatory = $false)]
    [string] $Subscription
)

$ErrorActionPreference = "Stop"

if (-not (Get-Module -ListAvailable -Name Az.KeyVault)) {
    throw "Az.KeyVault is not installed. Install with: Install-Module Az.KeyVault -Scope CurrentUser"
}

Import-Module Az.KeyVault -ErrorAction Stop

if ($Subscription) {
    Set-AzContext -Subscription $Subscription | Out-Null
}

foreach ($name in $SecretName) {
    $secure = Read-Host -AsSecureString -Prompt "Value for secret '$name' in vault '$VaultName' (hidden)"
    Set-AzKeyVaultSecret -VaultName $VaultName -Name $name -SecretValue $secure | Out-Null
    $secure.Dispose()
    Write-Host "Secret '$name' set in vault '$VaultName'."
}
