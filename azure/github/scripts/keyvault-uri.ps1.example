# SPDX-License-Identifier: MPL-2.0
# Print Azure Key Vault base URI (properties.vaultUri), e.g. https://myvault.vault.azure.net/
# For Azure Container Apps keyvaultref secrets, append: secrets/<SecretName>
# (<SecretName>: lowercase kebab-case fits Key Vault and Azure Container Apps; ACA secret names are max 20 chars.)
#   Full URI (latest version): https://myvault.vault.azure.net/secrets/MySecret
# See: https://learn.microsoft.com/en-us/azure/container-apps/manage-secrets?tabs=azure-cli
#
# Copy to keyvault-uri.ps1 and run non-interactively, e.g.:
#   .\keyvault-uri.ps1 -VaultName myvault
#   .\keyvault-uri.ps1 -VaultName myvault -Subscription "00000000-0000-0000-0000-000000000000"
#
# To upload secret bytes from a file without echoing them on the command line:
#   az keyvault secret set --vault-name myvault --name MySecret --file path\to\secret.txt
# Or use set-keyvault-secret-from-file.ps1.example in this directory.

param(
    [Parameter(Mandatory = $true, HelpMessage = "Key Vault name")]
    [string] $VaultName,

    [Parameter(Mandatory = $false)]
    [string] $Subscription
)

$ErrorActionPreference = "Stop"

if ($Subscription) {
    az account set --subscription $Subscription | Out-Null
}

az keyvault show --name $VaultName --query properties.vaultUri -o tsv
