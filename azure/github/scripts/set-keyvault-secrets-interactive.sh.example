#!/usr/bin/env bash
# SPDX-License-Identifier: MPL-2.0
# Prompt for each Key Vault secret value (hidden input) and upload without putting values on the command line.
# Copy to set-keyvault-secrets-interactive.sh, chmod +x, then run, e.g.:
#   ./set-keyvault-secrets-interactive.sh myvault webex-token-database other-secret
#   ./set-keyvault-secrets-interactive.sh --subscription 00000000-0000-0000-0000-000000000000 myvault webex-token-database
#
# Uses: az keyvault secret set --file /dev/fd/0 with the secret bytes from stdin (printf, no trailing newline).
# Reference: https://learn.microsoft.com/en-us/cli/azure/keyvault/secret?view=azure-cli-latest#az-keyvault-secret-set
#
set -euo pipefail

usage() {
    echo "Usage: $0 [--subscription SUBSCRIPTION_ID_OR_NAME] VAULT_NAME SECRET_NAME [SECRET_NAME ...]" >&2
    exit 1
}

subscription=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --subscription)
            [[ $# -ge 2 ]] || usage
            subscription="$2"
            shift 2
            ;;
        -h | --help)
            usage
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 2 ]]; then
    usage
fi

vault_name="$1"
shift
secret_names=("$@")

if [[ -n "$subscription" ]]; then
    az account set --subscription "$subscription" >/dev/null
fi

for secret_name in "${secret_names[@]}"; do
    value=""
    # Bash read -s: no echo while typing; -r: no backslash escapes
    read -r -s -p "Value for secret '${secret_name}' in vault '${vault_name}' (hidden): " value
    echo
    # printf (not echo) avoids trailing newline altering the stored secret
    printf '%s' "$value" | az keyvault secret set --vault-name "$vault_name" --name "$secret_name" --file /dev/fd/0 >/dev/null
    unset value
    echo "Secret '${secret_name}' set in vault '${vault_name}'."
done
