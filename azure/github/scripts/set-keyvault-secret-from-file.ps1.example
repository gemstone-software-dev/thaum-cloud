# SPDX-License-Identifier: MPL-2.0
# Set a Key Vault secret from a file (avoids putting the secret on the command line).
# Copy to set-keyvault-secret-from-file.ps1 and run, e.g.:
#   .\set-keyvault-secret-from-file.ps1 -VaultName myvault -SecretName webex-token-database -FilePath .\token.txt
#
# Uses: az keyvault secret set --file
# Reference: https://learn.microsoft.com/en-us/cli/azure/keyvault/secret?view=azure-cli-latest#az-keyvault-secret-set

param(
    [Parameter(Mandatory = $true)]
    [string] $VaultName,

    [Parameter(Mandatory = $true)]
    [string] $SecretName,

    [Parameter(Mandatory = $true)]
    [string] $FilePath,

    [Parameter(Mandatory = $false)]
    [string] $Subscription
)

$ErrorActionPreference = "Stop"

if (-not (Test-Path -LiteralPath $FilePath -PathType Leaf)) {
    throw "File not found: $FilePath"
}

if ($Subscription) {
    az account set --subscription $Subscription | Out-Null
}

az keyvault secret set --vault-name $VaultName --name $SecretName --file $FilePath | Out-Null
Write-Host "Secret '$SecretName' set in vault '$VaultName'."
Write-Host "Remove or secure-wipe '$FilePath' when finished if it contains sensitive material."
